{
  "version": 2,
  "builds": [
    {
      "src": "requirements.txt",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12.6",
        "installCommand": "pip install -r requirements.txt",
        "buildCommand": "pip install flask-gunicorn && gunicorn app:app",
        "outputDirectory": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    }
  ]
}